class Solution {
public:
    bool isAlphanum(char ch) {return(ch>='a' && ch<='z' || ch>='0' && ch<='9' || ch>='A' && ch<='Z');}
    bool isPalindrome(string s) {
        for(char &ch : s)
        ch = tolower(ch);

        int i =0;
        int j=s.length()-1 ;
        while(i<j){
            if(!isAlphanum(s[i])) {i++; continue;}
            if(!isAlphanum(s[j])) {j--; continue;}
            if(s[i] != s[j]) return false;
            i++; j--;
        }
        return true;
        }
};


