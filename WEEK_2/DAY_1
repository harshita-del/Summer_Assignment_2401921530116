class Solution {
public:
    bool isAnagram(string s, string t) {
        //Using Sorting

        // sort(s.begin(),s.end());
        // sort(t.begin(),t.end());

        // return s==t;


        // Frequency Count
        
        if(s.length() != t.length()) return false;

        vector<int> freq(26,0);  

        for(char &ch: s){
            freq[ch-'a']++;
        }

        for(char &ch: t){
            freq[ch-'a']--;
        }
        
        for(int i=0;i<26;i++){
            if(freq[i] != 0){
                return false;
            }
        }
        return true;
    }
};









