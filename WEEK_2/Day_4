class Solution {
public:
    string reverseWords(string s) {
        stack<char> st;
        string ans="";

        for(char ch: s){
            if(ch!=' '){
                st.push(ch);
            }else{
                while(!st.empty()){
                    ans +=st.top();
                    st.pop();
                }
                ans+=' ';
            }
        }
        while(!st.empty()){
            ans+=st.top();
            st.pop();
        }
        return ans;
    }
};



