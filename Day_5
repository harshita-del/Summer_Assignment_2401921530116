class Solution {
public:
    void reverseString(vector<char>& s) {
       int l =0;
       int r=s.size()-1;

       while(l < r){
       swap(s[l],s[r]);
       l++;
       r--;
       }
    }
};


//3.

class Solution {
public:
    string longestCommonPrefix(vector<string>& strs) {
        string ans="";
        int n=strs.size();
        for(int i=0;i<strs[0].length();i++){
            char ch=strs[0][i];
            bool match = true;

         for(int j=1;j<n;j++){
                if( strs[j].size() < i+1 || strs[j][i] != ch){
                    match = false;
                    break;
                }
            }
            if(match == false)
            break;
            else
            ans.push_back(ch);
        }
        return ans;
    }
};
